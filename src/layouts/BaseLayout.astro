---
import '@/styles/global.css';
import SiteNav from '@/components/SiteNav.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Personal site of Ray Weiss. Brooklyn wargame designer, running four businesses and a band.',
  image = '/og-image.png',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(image, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Ray Weiss" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Ray Weiss. Brooklyn wargame designer, running four businesses and a band."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body class="bg-background text-foreground font-sans antialiased">
    <header
      class="sticky top-0 z-10 border-b border-border bg-background/95 px-6 py-4 backdrop-blur lg:hidden"
    >
      <a
        href="/"
        class="flex items-center gap-2 font-sans text-lg font-medium tracking-tight text-foreground"
      >
        <img
          src="/wargame-counter.png"
          alt=""
          width="20"
          height="20"
          class="h-5 w-5"
        />
        Ray Weiss
      </a>
      <div class="mt-3">
        <SiteNav variant="topbar" />
      </div>
    </header>

    <aside
      class="hidden lg:fixed lg:inset-y-0 lg:left-0 lg:flex lg:w-64 lg:flex-col lg:overflow-y-auto lg:border-r lg:border-border lg:bg-background lg:px-8 lg:py-12"
    >
      <a
        href="/"
        class="flex items-center gap-2 font-sans text-lg font-medium tracking-tight text-foreground"
      >
        <img
          src="/wargame-counter.png"
          alt=""
          width="20"
          height="20"
          class="h-5 w-5"
        />
        Ray Weiss
      </a>
      <div class="mt-12 flex-1">
        <SiteNav variant="sidebar" />
      </div>
    </aside>

    <main class="lg:pl-64">
      <div class="flex min-h-screen flex-col">
        <div class="flex-1">
          <slot />
        </div>
        <footer
          id="contact"
          class="mt-16 border-t border-border px-6 py-12 lg:px-16"
        >
          <div class="max-w-3xl">
            <h2
              class="font-sans text-xs font-medium uppercase tracking-wider text-muted"
            >
              Contact
            </h2>
            <ul class="mt-4 space-y-1 font-mono text-sm">
              <li>
                <a
                  href="mailto:lerugray@gmail.com"
                  class="text-link hover:text-link-hover"
                >
                  lerugray@gmail.com
                </a>
              </li>
              <li>
                <a
                  href="https://github.com/lerugray"
                  class="text-link hover:text-link-hover"
                >
                  github.com/lerugray
                </a>
              </li>
              <li>
                <a
                  href="https://lerug.bandcamp.com"
                  class="text-link hover:text-link-hover"
                >
                  lerug.bandcamp.com
                </a>
              </li>
              <li>
                <a
                  href="https://conflict-simulations-llc.itch.io"
                  class="text-link hover:text-link-hover"
                >
                  conflict-simulations-llc.itch.io
                </a>
              </li>
            </ul>
          </div>
        </footer>
      </div>
    </main>
  </body>
</html>
