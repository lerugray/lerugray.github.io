---
import '@/styles/global.css';
import SiteNav from '@/components/SiteNav.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Personal site of Ray Weiss. Writing, games, tools, music. Founder of Conflict Simulations LLC.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground font-sans antialiased">
    <header
      class="sticky top-0 z-10 border-b border-border bg-background/95 px-6 py-4 backdrop-blur lg:hidden"
    >
      <a
        href="/"
        class="block font-sans text-lg font-medium tracking-tight text-foreground"
      >
        Ray Weiss
      </a>
      <div class="mt-3">
        <SiteNav variant="topbar" />
      </div>
    </header>

    <aside
      class="hidden lg:fixed lg:inset-y-0 lg:left-0 lg:flex lg:w-64 lg:flex-col lg:overflow-y-auto lg:border-r lg:border-border lg:bg-background lg:px-8 lg:py-12"
    >
      <a
        href="/"
        class="block font-sans text-lg font-medium tracking-tight text-foreground"
      >
        Ray Weiss
      </a>
      <div class="mt-12 flex-1">
        <SiteNav variant="sidebar" />
      </div>
    </aside>

    <main class="lg:pl-64">
      <div class="flex min-h-screen flex-col">
        <div class="flex-1">
          <slot />
        </div>
        <footer
          id="contact"
          class="mt-16 border-t border-border px-6 py-12 lg:px-16"
        >
          <div class="max-w-3xl">
            <h2
              class="font-sans text-xs font-medium uppercase tracking-wider text-muted"
            >
              Contact
            </h2>
            <ul class="mt-4 space-y-1 font-mono text-sm">
              <li>
                <a
                  href="mailto:lerugray@gmail.com"
                  class="text-link hover:text-link-hover"
                >
                  lerugray@gmail.com
                </a>
              </li>
              <li>
                <a
                  href="https://github.com/lerugray"
                  class="text-link hover:text-link-hover"
                >
                  github.com/lerugray
                </a>
              </li>
              <li>
                <a
                  href="https://lerug.bandcamp.com"
                  class="text-link hover:text-link-hover"
                >
                  lerug.bandcamp.com
                </a>
              </li>
              <li>
                <a
                  href="https://conflict-simulations-llc.itch.io"
                  class="text-link hover:text-link-hover"
                >
                  conflict-simulations-llc.itch.io
                </a>
              </li>
            </ul>
          </div>
        </footer>
      </div>
    </main>
  </body>
</html>
