---
interface Props {
  title: string;
  publishDate: Date;
  readingTime?: string;
}

const { title, publishDate, readingTime } = Astro.props;

const dateFormatted = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="px-6 py-24 lg:px-16">
  <div class="mx-auto max-w-[65ch]">
    <header class="mb-16">
      <h1
        class="font-sans text-4xl font-medium tracking-tight text-foreground lg:text-5xl"
      >
        {title}
      </h1>
      <p class="mt-6 font-mono text-xs uppercase tracking-wider text-muted">
        <time datetime={publishDate.toISOString()}>{dateFormatted}</time>
        {
          readingTime && (
            <>
              <span class="mx-3 text-subtle">·</span>
              <span>{readingTime}</span>
            </>
          )
        }
      </p>
    </header>
    <div class="essay-body">
      <slot />
    </div>
  </div>
</article>

<style>
  .essay-body :global(p) {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-foreground);
    margin-top: 1.5rem;
  }

  .essay-body :global(> p:first-child) {
    margin-top: 0;
  }

  .essay-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 4rem;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .essay-body :global(h3) {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .essay-body :global(a) {
    color: var(--color-link);
    text-decoration-line: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 150ms;
  }

  .essay-body :global(a:hover) {
    color: var(--color-link-hover);
  }

  .essay-body :global(strong) {
    font-weight: 600;
    color: var(--color-foreground);
  }

  .essay-body :global(em) {
    font-style: italic;
  }

  .essay-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 4rem auto;
    width: 6rem;
  }

  .essay-body :global(blockquote) {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-muted);
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
  }

  .essay-body :global(ul),
  .essay-body :global(ol) {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-foreground);
    margin-top: 1rem;
    padding-left: 1.5rem;
  }

  .essay-body :global(li) {
    margin-top: 0.5rem;
  }

  .essay-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background-color: var(--color-surface);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
  }
</style>
