---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Conflict Simulations LLC | Ray Weiss"
  description="Conflict Simulations LLC. Ray Weiss's imprint for historical board wargames and digital games."
>
  <main class="px-6 py-24 lg:px-16">
    <div class="mx-auto max-w-3xl">
      <h1
        class="font-sans text-4xl font-medium tracking-tight text-foreground lg:text-5xl"
      >
        Conflict Simulations LLC
      </h1>
      <p class="mt-6 font-serif text-lg text-muted">
        Ray Weiss's imprint for board wargames and digital games.
      </p>

      <div class="mt-10 border-y border-border py-4">
        <p
          class="font-mono text-xs font-medium uppercase tracking-wider text-muted"
        >
          <span>~30 published wargames</span>
          <span class="mx-3 text-subtle">·</span>
          <span>CSR Award nominee</span>
          <span class="mx-3 text-subtle">·</span>
          <span>Published by Multi-Man Publishing (Rostov 41, SCS series)</span>
        </p>
      </div>

      <section class="mt-16">
        <h2
          class="font-mono text-xs font-medium uppercase tracking-wider text-muted"
        >
          Board wargames
        </h2>
        <div class="prose-body mt-6">
          <p>
            Operational and strategic-scale historical wargames. Print-on-demand
            fulfillment out of Brooklyn. The full catalog is at <a
              href="https://consimsltd.com/shop">consimsltd.com/shop</a>.
          </p>
          <p>
            Selected titles: 1950 Korea, 1973 Arab-Israeli War, Alma, Koniggratz,
            Imperial Bayonets, DAMOS.
          </p>
        </div>
      </section>

      <section class="mt-16">
        <h2
          class="font-mono text-xs font-medium uppercase tracking-wider text-muted"
        >
          Digital games
        </h2>
        <div class="prose-body mt-6">
          <p>
            Four titles released on itch under the CSL brand. The full itch
            catalog is at <a href="https://conflict-simulations-llc.itch.io"
              >conflict-simulations-llc.itch.io</a>.
          </p>
        </div>
        <div class="mt-8 overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-border">
                <th
                  class="py-3 pr-6 font-mono text-xs font-medium uppercase tracking-wider text-muted"
                  >Title</th
                >
                <th
                  class="py-3 pr-6 font-mono text-xs font-medium uppercase tracking-wider text-muted"
                  >Price</th
                >
                <th
                  class="py-3 pr-6 font-mono text-xs font-medium uppercase tracking-wider text-muted"
                  >Format</th
                >
                <th
                  class="py-3 font-mono text-xs font-medium uppercase tracking-wider text-muted"
                  >Description</th
                >
              </tr>
            </thead>
            <tbody class="font-serif">
              <tr class="border-b border-border transition-colors hover:bg-surface">
                <td class="py-4 pr-6">
                  <a
                    href="/devforge"
                    class="font-medium text-foreground hover:text-link-hover"
                    >Devforge</a
                  >
                </td>
                <td class="py-4 pr-6 font-mono tabular-nums text-muted">$9</td>
                <td class="py-4 pr-6 text-muted">Windows desktop</td>
                <td class="py-4 text-muted">
                  A game dev terminal that knows your project cold.
                </td>
              </tr>
              <tr class="border-b border-border transition-colors hover:bg-surface">
                <td class="py-4 pr-6">
                  <a
                    href="/conflict-simulations-llc/veridian-contraption"
                    class="font-medium text-foreground hover:text-link-hover"
                    >Veridian Contraption</a
                  >
                </td>
                <td class="py-4 pr-6 font-mono tabular-nums text-muted">$3</td>
                <td class="py-4 pr-6 text-muted">Rust terminal</td>
                <td class="py-4 text-muted">
                  A world-simulator of considerable density and dubious intent.
                </td>
              </tr>
              <tr class="border-b border-border transition-colors hover:bg-surface">
                <td class="py-4 pr-6">
                  <a
                    href="/conflict-simulations-llc/death-of-an-empire"
                    class="font-medium text-foreground hover:text-link-hover"
                    >Death Of An Empire</a
                  >
                </td>
                <td class="py-4 pr-6 font-mono tabular-nums text-muted">$3.99</td
                >
                <td class="py-4 pr-6 text-muted">Rust terminal</td>
                <td class="py-4 text-muted">Franco-Prussian War, 1870.</td>
              </tr>
              <tr class="transition-colors hover:bg-surface">
                <td class="py-4 pr-6">
                  <a
                    href="https://conflict-simulations-llc.itch.io/prigozhins-march-of-justice"
                    class="font-medium text-foreground hover:text-link-hover"
                    >Prigozhin's March of Justice</a
                  >
                </td>
                <td class="py-4 pr-6 font-mono tabular-nums text-muted">$2.99</td
                >
                <td class="py-4 pr-6 text-muted">Digital</td>
                <td class="py-4 text-muted">
                  Digital version of Ray's solitaire board wargame.
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mt-16">
        <h2
          class="font-mono text-xs font-medium uppercase tracking-wider text-muted"
        >
          A Contemporary Guide to Wargame Design
        </h2>
        <div class="prose-body mt-6">
          <p>
            A practitioner's book on designing historical wargames. Roughly
            twenty-three chapters, drawing on thirty shipped titles. Drafting
            now; free online reader planned.
          </p>
          <p>
            Public repo: <a href="https://github.com/lerugray/wargame-design-book"
              >github.com/lerugray/wargame-design-book</a
            >.
          </p>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
