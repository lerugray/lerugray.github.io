---
import { navGroups, isActive } from '@/data/navigation';

interface Props {
  variant: 'sidebar' | 'topbar';
}

const { variant } = Astro.props;
const currentPath = Astro.url.pathname;

const flatItems = navGroups.flatMap((g) => g.items);
---

{
  variant === 'sidebar' && (
    <nav aria-label="Primary">
      {navGroups.map((group) => (
        <div class="nav-group">
          <div class="nav-group-label">{group.label}</div>
          <ul>
            {group.items.map(({ href, label }) => (
              <li>
                <a href={href} aria-current={isActive(href, currentPath) ? 'page' : undefined}>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  )
}

{
  variant === 'topbar' && (
    <nav aria-label="Primary" class="-mx-6 overflow-x-auto">
      <ul class="flex gap-5 whitespace-nowrap px-6 text-sm">
        {flatItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href, currentPath) ? 'page' : undefined}
              class:list={[
                'inline-block border-b-2 pb-1 transition-colors',
                isActive(href, currentPath)
                  ? 'border-link text-foreground'
                  : 'border-transparent text-muted hover:text-foreground',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
