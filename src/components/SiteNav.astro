---
import { navItems, isActive } from '@/data/navigation';

interface Props {
  variant: 'sidebar' | 'topbar';
}

const { variant } = Astro.props;
const currentPath = Astro.url.pathname;
---

{
  variant === 'sidebar' && (
    <nav aria-label="Primary">
      <ul class="space-y-1">
        {navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href, currentPath) ? 'page' : undefined}
              class:list={[
                'block border-l-2 py-1.5 pl-4 text-sm transition-colors',
                isActive(href, currentPath)
                  ? 'border-accent text-foreground'
                  : 'border-transparent text-muted hover:border-border hover:text-foreground',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

{
  variant === 'topbar' && (
    <nav aria-label="Primary" class="-mx-6 overflow-x-auto">
      <ul class="flex gap-5 whitespace-nowrap px-6 text-sm">
        {navItems.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(href, currentPath) ? 'page' : undefined}
              class:list={[
                'inline-block border-b-2 pb-1 transition-colors',
                isActive(href, currentPath)
                  ? 'border-accent text-foreground'
                  : 'border-transparent text-muted hover:text-foreground',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
