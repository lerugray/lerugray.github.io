# vault: all subfolders tracked across machines so the home PC can sync them.
# IP rule enforced in vault/README.md — no proprietary prompts, customer data,
# pricing margins, internal methodology, or unpublished book chapters in ANY vault file.

# Claude Code working state (permissions, local session data) — not for public repo.
# SKILLs are tracked cross-machine so coding agents on every PC inherit them;
# everything else (settings.local.json, session caches) stays local.
.claude/*
!.claude/skills/

# Claude Design preview output (extracted reference HTMLs + assets + uploads/
# mirror). Local working reference; canonical artifact lives in the private
# repo at design-payloads/<id>/.
claude-design-output/

# Visual audit artifacts — local screenshot output from scripts/audit-site.mjs
audit-screenshots/

# 2026-04-24 overnight-bot sanity cleanup � untracked artifacts that were blocking GS dispatcher clean-tree preflight
drafts/

# GS state junction (private-state safety; defensive add 2026-04-30 per
# cross-project gitignore audit. personal-site migrated to private-state
# 2026-04-28; state/<id>/ junction may not exist locally yet, but if a
# bot cycle or Cursor session creates it later, git add -A would leak
# private MISSION.md / tasks.json content).
state/

# GS dispatcher per-project worktree — bot scratch space, never tracked.
.bot-worktree/

